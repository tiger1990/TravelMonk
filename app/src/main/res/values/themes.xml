<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Post-splash theme: applied after the splash screen exits -->
    <style name="Theme.TravelMonk.NoActionBar" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Launch theme: shown during cold start, hands off to NoActionBar after splash -->
    <style name="Theme.TravelMonk" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/travel_orange</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.TravelMonk.NoActionBar</item>

        <!-- Make status bar transparent during splash to prevent grey flash -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
